---
// src/components/Hero.astro
import { PhoneCall, Sparkles } from 'lucide-astro';

const waNumber = "6285712425961"; 

const msgKonsultasi = encodeURIComponent("Halo Bregas Elektrik, saya ingin berkonsultasi mengenai layanan instalasi listrik.");
const linkKonsultasi = `https://wa.me/${waNumber}?text=${msgKonsultasi}`;

// PERBAIKAN: Mengganti link WA penawaran menjadi rute internal menuju section Layanan
const linkLayanan = "/#layanan"; 

const bgImage = "/bg-hero.jpg";
---

<section 
  class="relative w-full min-h-screen flex items-center bg-cover bg-center bg-no-repeat text-white pt-20 border-b border-border-custom/20"
  style={`background-image: url('${bgImage}');`}
>
  <div class="absolute inset-0 bg-black/55 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10 w-full py-12 md:py-20">
    <div class="max-w-2xl text-left">

      <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight mb-4 drop-shadow-md">
        Terima Pasang & Perbaikan <span class="text-accent">Instalasi Listrik</span> Aman & Terpercaya
      </h1>

      <p class="text-sm sm:text-base md:text-lg text-slate-200 leading-relaxed mb-8 max-w-xl drop-shadow-sm">
        Nggak perlu pusing soal korsleting turun-naik atau pasang jalur kabel baru. Semua ditangani langsung oleh teknisi berpengalaman. Siap survei ke lokasi Anda.
      </p>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center justify-start gap-4">
        
        <a 
          href={linkKonsultasi}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent/80 text-primary font-bold py-3 px-6 rounded-xl shadow-md transition-all duration-200 group transform hover:-translate-y-0.5 text-sm"
        >
          <PhoneCall class="w-4 h-4 transition-transform group-hover:scale-110" />
          Tanya / Konsultasi Dulu
        </a>

        <a 
          href={linkLayanan}
          class="inline-flex items-center justify-center gap-2 bg-black/40 hover:bg-black/60 text-white font-bold py-3 px-6 rounded-xl border border-white/20 backdrop-blur-xs transition-all duration-200 text-sm group"
        >
          <Sparkles class="w-4 h-4 text-accent group-hover:scale-110 transition-transform" />
          Lihat Layanan Kami
        </a>
        
      </div>

    </div>
  </div>
</section>