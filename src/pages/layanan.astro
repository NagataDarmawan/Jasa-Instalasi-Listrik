---
// src/components/Services.astro
import { ArrowUpRight, ImageOff } from 'lucide-astro';
import '../styles/global.css';

const services = [
  { 
    id: "serv-1", 
    title: "Instalasi Listrik Rumah", 
    description: "Melayani perancangan jaminan keamanan hunian baru maupun lama. Cakupan tindakan meliputi: Instalasi baru, Renovasi instalasi keseluruhan, serta Penambahan titik lampu ruangan.", 
    image: "/bg-hero.jpg" 
  },
  { 
    id: "serv-2", 
    title: "Instalasi Listrik Ruko & Toko", 
    description: "Integrasi sistem kelistrikan komersial terstruktur pembagian beban aman untuk operasional usaha Anda, mencakup: Ruko, Toko retail, Kafe kecil, dan berbagai jenis Tempat usaha.", 
    image: "/bg-hero.jpg" 
  },
  { 
    id: "serv-3", 
    title: "Penambahan Daya Listrik", 
    description: "Solusi satu pintu peningkatan pasokan energi listrik dari PLN tanpa kendala interupsi operasional, meliputi: Persiapan teknis instalasi and Penyesuaian instalasi setelah daya bertambah.", 
    image: "/bg-hero.jpg" 
  },
  { 
    id: "serv-4", 
    title: "Pemasangan & Penggantian MCB", 
    description: "Peremajaan sistem proteksi arus berlebih untuk menekan risiko kebakaran akibat korsleting, melayani pemasangan: MCB utama panel, MCB cabang distribusi, hingga penggantian Box MCB.", 
    image: "/bg-hero.jpg" 
  },
  { 
    id: "serv-5", 
    title: "Perbaikan Instalasi Listrik", 
    description: "Layanan penanganan darurat penelusuran gangguan (*troubleshooting*) kelistrikan akibat: Korsleting arus pendek, Stop kontak rusak, Saklar rusak, Lampu mati total, hingga Kabel putus.", 
    image: "/bg-hero.jpg" 
  },
  { 
    id: "serv-6", 
    title: "Pemasangan Lampu & Stop Kontak", 
    description: "Ekstensi fungsionalitas dan estetika pencahayaan serta titik daya bangunan Anda, mencakup penempatan: Lampu indoor, Lampu outdoor eksterior, Lampu taman, dan penambahan unit Stop kontak.", 
    image: "/bg-hero.jpg" 
  },
  { 
    id: "serv-7", 
    title: "Pengecekan & Perawatan Instalasi", 
    description: "Tindakan preventif berkala guna memantau kelayakan isolasi sirkuit dan kesehatan koneksi komponen kelistrikan melalui prosedur standar Pemeriksaan instalasi menyeluruh.", 
    image: "/bg-hero.jpg" 
  }
];
---

<section id="layanan" class="py-24 bg-white border-b border-border-custom/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="mb-12">
      <h2 class="text-xs font-bold tracking-wider uppercase text-accent mb-2">Layanan Profesional</h2>
      <p class="text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-tight text-primary">
        Layanan Kelistrikan Terintegrasi Berstandar PUIL (Persyaratan Umum Instalasi Listrik)
      </p>
      <div class="w-16 h-1 bg-accent mt-4"></div>
    </div>

    {/* PERBAIKAN: Mengubah bg-slate-50 menjadi bg-primary (Biru) pada layout card utama */}
    <div class="bg-primary border border-white/[0.08] rounded-2xl overflow-hidden grid grid-cols-1 lg:grid-cols-12 gap-0 shadow-xl">
      
      {/* Kolom Kiri: Pratinjau Gambar */}
      <div class="lg:col-span-4 bg-black/20 relative min-h-[280px] lg:min-h-[480px] overflow-hidden flex items-center justify-center pointer-events-none border-b lg:border-b-0 lg:border-r border-white/[0.08]">
        <div class="absolute inset-0 flex flex-col items-center justify-center text-white/30">
          <ImageOff class="w-10 h-10 stroke-[1.5]" />
          <span class="text-[10px] uppercase tracking-widest font-bold mt-2 opacity-60">Pratinjau Gambar</span>
        </div>

        {services.map((item, index) => (
          <img 
            id={`img-${item.id}`}
            src={item.image} 
            alt={item.title}
            loading="lazy"
            class={`w-full h-full object-cover absolute inset-0 z-10 pointer-events-none transition-none transform-none ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
            onerror="this.style.opacity='0';" 
          />
        ))}
      </div>

      {/* Kolom Kanan: Daftar Layanan (PERBAIKAN: bg-white diubah menjadi bg-primary/40 atau transparan agar menyatu dengan card biru) */}
      <div class="lg:col-span-8 p-6 sm:p-8 flex flex-col justify-between bg-primary/40">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-1">
          {services.map((item, index) => {
            const isFirst = index === 0;
            return (
              /* PERBAIKAN: Border pembatas baris menggunakan putih transparan border-white/10 */
              <div class="border-b border-white/10 py-1">
                <button
                  data-target={item.id}
                  class="service-trigger w-full text-left py-2 flex items-start gap-3 transition-all focus:outline-none"
                >
                  {/* Indikator Baris Sisi Kiri */}
                  <div class={`w-1 h-5 shrink-0 transition-colors duration-300 rounded-full mt-1 ${isFirst ? 'bg-accent' : 'bg-white/20'}`}></div>
                  
                  <div class="w-full">
                    {/* PERBAIKAN: Mengganti warna default tidak aktif dari abu-abu gelap ke putih transparan (text-white/50) */}
                    <h3 class={`font-bold text-sm md:text-base tracking-tight transition-colors duration-300 ${isFirst ? 'text-accent' : 'text-white/50'}`}>
                      {item.title}
                    </h3>
                    
                    {/* Deskripsi Box */}
                    <div 
                      id={`desc-${item.id}`}
                      class={`service-desc overflow-hidden transition-all duration-300 ease-in-out ${isFirst ? 'max-h-40 opacity-100 mt-1.5' : 'max-h-0 opacity-0'}`}
                    >
                      {/* PERBAIKAN: Mengubah warna text agar kontras dan mudah dibaca (text-white/80) */}
                      <p class="text-xs text-white/80 leading-relaxed pr-2 font-normal">
                        {item.description}
                      </p>
                    </div>
                  </div>
                </button>
              </div>
            )
          })}
        </div>

        {/* Bagian Tombol Aksi di Bawah (PERBAIKAN: Menyesuaikan border dan tombol kontras tinggi) */}
        <div class="mt-8 pt-4 border-t border-white/10 flex justify-end">
          <a 
            href="/catalogLayanan"
            class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-primary bg-accent hover:bg-accent/90 py-3.5 px-6 rounded-md transition-all duration-200 shadow-md group"
          >
            <span>Pesan Jasa Sekarang</span>
            <ArrowUpRight class="w-4 h-4 text-primary transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </a>
        </div>

      </div>

    </div>

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.service-trigger');
    
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('data-target');
        if (!targetId) return;

        // Reset semua menu ke kondisi mati (Muted)
        triggers.forEach(t => {
          const tId = t.getAttribute('data-target');
          const indicator = t.querySelector('.w-1');
          const title = t.querySelector('h3');
          const desc = document.getElementById(`desc-${tId}`);
          const img = document.getElementById(`img-${tId}`);

          indicator?.classList.remove('bg-accent');
          indicator?.classList.add('bg-white/20');
          
          // PERBAIKAN: Mengembalikan warna teks tidak aktif ke mode kontras gelap (text-white/50)
          title?.classList.remove('text-accent');
          title?.classList.add('text-white/50');
          
          if (desc) {
            desc.classList.remove('max-h-40', 'opacity-100', 'mt-1.5');
            desc.classList.add('max-h-0', 'opacity-0');
          }
          if (img) {
            img.classList.remove('opacity-100');
            img.classList.add('opacity-0');
          }
        });

        // Aktifkan murni hanya yang di-KLIK oleh user
        const currentIndicator = trigger.querySelector('.w-1');
        const currentTitle = trigger.querySelector('h3');
        const currentDesc = document.getElementById(`desc-${targetId}`);
        const currentImg = document.getElementById(`img-${targetId}`);

        currentIndicator?.classList.remove('bg-white/20');
        currentIndicator?.classList.add('bg-accent');
        
        currentTitle?.classList.remove('text-white/50');
        currentTitle?.classList.add('text-accent');

        if (currentDesc) {
          currentDesc.classList.remove('max-h-0', 'opacity-0');
          currentDesc.classList.add('max-h-40', 'opacity-100', 'mt-1.5');
        }
        if (currentImg) {
          currentImg.classList.remove('opacity-0');
          currentImg.classList.add('opacity-100');
        }
      });
    });
  });
</script>